APP_MODE=mac_native

ASR_PROVIDER=local_whisper
WHISPER_RUNTIME=whisper_cpp
WHISPER_MODEL=large-v3-turbo
WHISPER_MODEL_PATH=
WHISPER_LANGUAGE=zh
WHISPER_KEEP_MODEL_LOADED=true
WHISPER_USE_METAL=true
WHISPER_USE_COREML=false
WHISPER_ENABLE_VAD=true
WHISPER_MAX_SEGMENT_SECONDS=30
WHISPER_THREADS=auto

LLM_PROVIDER=volcengine_ark
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_MODEL=
ARK_TEMPERATURE=0.2
ARK_TIMEOUT_SECONDS=20

# 可选：把 LLM_PROVIDER 改成 custom_openai_compatible 后使用。
# 你的服务需要兼容 OpenAI /chat/completions：
# POST {{CUSTOM_LLM_BASE_URL}}/{{CUSTOM_LLM_PATH}}
# body: {model, temperature, messages, response_format}
# response: {choices:[{message:{content:"JSON string"}}]}
CUSTOM_LLM_BASE_URL=http://127.0.0.1:8000/v1
CUSTOM_LLM_PATH=chat/completions
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=
CUSTOM_LLM_AUTH_HEADER=Authorization
CUSTOM_LLM_AUTH_SCHEME=Bearer
CUSTOM_LLM_REQUIRES_API_KEY=false
CUSTOM_LLM_EXTRA_HEADERS_JSON=

DICTATION_HOTKEY=Option+Space
EDIT_SELECTION_HOTKEY=Option+Shift+Space

SAVE_HISTORY=true
SAVE_AUDIO=false
RESTORE_CLIPBOARD_AFTER_PASTE=true
DEFAULT_STYLE_PROFILE=auto
LOG_LEVEL=info
